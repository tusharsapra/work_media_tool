# --- Server ---
PORT=3001

# LLM_MODE controls whether the backend ever calls Anthropic.
#   mock  (default) — no live API calls. Server boots without ANTHROPIC_API_KEY.
#   live           — only used when ANTHROPIC_API_KEY is present; otherwise auto-falls back to mock.
LLM_MODE=mock
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_CALLS_PER_SESSION=50

# --- Web (Vite) ---
# VITE_ prefix exposes the variable to the client bundle.
VITE_API_BASE=/api
